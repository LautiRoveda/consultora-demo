# Plantilla de variables de entorno. Copiá este archivo a `.env.local` y llená los valores reales.
# `.env.local` está gitignored — nunca se commitea. Solo `.env.example` queda en repo.
#
# Ver `docs/technical/04-folder-structure.md` (sección "Variables de entorno") y
# `supabase/README.md` para detalle.

# ── Supabase (T-005) ─────────────────────────────────────────────────────────
# Dashboard del proyecto: https://supabase.com/dashboard/project/<SUPABASE_PROJECT_REF>
# Settings → API trae las URL + ANON + SERVICE_ROLE.
# Settings → Database trae la DB password (la fijás vos al crear el proyecto).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# ── Sentry (T-007) ───────────────────────────────────────────────────────────
# Dashboard: https://sentry.io/organizations/<SENTRY_ORG>/projects/<SENTRY_PROJECT>/
# Settings → Projects → consultora-demo → Client Keys (DSN) → DSN público.
# El DSN no es secreto — el SDK del browser lo expone en el bundle.

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Solo dev: forzar envío real a Sentry desde NODE_ENV=development para validación
# end-to-end (ej: hit /api/test-error y verificar en sentry.io). En prod no
# tiene efecto porque ya está enabled por NODE_ENV. Dejar vacío en uso normal.
SENTRY_FORCE_ENABLE=

# Solo PRODUCCIÓN: token con scope project:releases + project:write para que
# `withSentryConfig` (next.config.ts) suba source maps en cada build.
# - NO se usa en local (pnpm dev / pnpm build local los emiten pero no los
#   sube — sin auth token el plugin queda silent).
# - NO se usa en CI propio (GitHub Actions, ci.yml).
# - SÍ se usa en T-022.5: cargado como EasyPanel env var del Service
#   `consultora-demo`, presente durante `docker build` (build arg). Si falta,
#   la app igual funciona — solo se pierde upload de source maps.
# Generación: sentry.io → User Settings → Auth Tokens → Create New Token con
# scopes mínimos (project:releases + project:write). Ver
# `docs/technical/06-deployment.md`.
SENTRY_AUTH_TOKEN=

# ── Site URL (T-009 + T-022.5-FU4) ───────────────────────────────────────────
# Usos:
#   - src/app/robots.ts + src/app/sitemap.ts → URLs absolutas del sitio.
#   - src/app/auth/callback/route.ts → base del redirect post-auth (T-022.5-FU4).
#     Necesario porque `request.url.origin` en VPS detrás de Traefik devuelve
#     el bind interno del container (0.0.0.0:80). El callback se rompe sin
#     este env seteado correctamente.
# Default si no se setea: https://consultorademo.com.ar (rompe E2E local).
# Prod (T-022.5): https://consultora-demo.test-ia.cloud (cargado en EasyPanel).
# Local + CI: http://localhost:3000 (matchea el server de Playwright webServer).

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Anthropic Claude API (T-020) ─────────────────────────────────────────────
# API key para generación de contenido de informes con Claude.
# Dashboard: https://console.anthropic.com/settings/keys
#
# Server-only — no usar prefix NEXT_PUBLIC. Leak = facturación ajena.
# El bundler de Next falla en build si algún Client Component importa env.ts.
#
# En CI: cargada como GitHub Secret. En prod: Vercel env var (Production + Preview).

ANTHROPIC_API_KEY=

# ── Pagos / Mercado Pago (T-070) ─────────────────────────────────────────────
# Precio del plan Pro en centavos ARS (sin decimales). Ejemplo "3000000" = ARS
# 30.000 = aprox USD 30 al FX actual. Lautaro lo ajusta manualmente cuando hay
# drift FX significativo (no hay BCRA lookup automático en MVP — futuro
# T-070-FU1 si emerge necesidad). Server-only — usado por T-071 al crear el
# preapproval en Mercado Pago Subscriptions API.

ARS_PRICE_MONTHLY=

# ── Tests E2E (T-018) ────────────────────────────────────────────────────────
# Los tests E2E con sesión real (`src/tests/e2e/auth-flows.spec.ts`) reusan
# las 3 vars de Supabase de arriba — NO necesitan vars adicionales.
#
#   Local:  `set -a && source .env.local && set +a && pnpm test:e2e`
#   CI:     mismas vars cargadas desde GitHub Secrets (ver `.github/workflows/ci.yml`).
#
# Detalles del setup + cleanup pattern + bypass de email rate limit:
#   src/tests/e2e/helpers/README.md

# ── Self-hosted VPS (T-022.5) ────────────────────────────────────────────────
# El deploy de producción NO usa más Vercel. Pasamos a VPS Hostinger Ubuntu
# 24.04 con EasyPanel (ADR-0007). Detalle en `docs/technical/06-deployment.md`.
#
# Cómo se cargan las env vars en prod:
#   1. EasyPanel → Project `agendalo` → Service `consultora-demo` → Environment.
#   2. Las 9 vars de arriba se cargan ahí, una por una.
#   3. EasyPanel las pasa al `docker build` como build args (las que necesita
#      build-time, ej. NEXT_PUBLIC_*, SENTRY_AUTH_TOKEN) y al container en
#      runtime via process.env.
#
# CI/CD trigger:
#   - GitHub Actions corre los 213+ tests en cada push (sin job de deploy).
#   - Deploy productivo: **click manual** en EasyPanel UI → Service consultora-demo
#     → "Implementar" después de cada merge a `main`. Build toma 2-5 min.
#   - Rationale: EasyPanel v2.30.0 Self-Hosted no expone Auto Deploy en UI; el
#     webhook URL custom tampoco está visible en esta versión. Revisitar en
#     upgrade — ver T-022.5-FU3 en docs/adr/0007-vps-hostinger-easypanel.md.
#   - Gate de CI verde: implícito por convención operacional (Lautaro solo
#     clickea Implementar después de mergear PR con CI verde). Reforzable con
#     branch protection rule: Settings → Branches → main → "Require status
#     checks to pass before merging" → CI.
#   - Secrets requeridos en GitHub Actions: las 4 de prod (Supabase + Anthropic).
#     No hay secret de deploy webhook.
