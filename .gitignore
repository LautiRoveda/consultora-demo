# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env*
!.env.example

# vercel
.vercel

# supabase CLI metadata (token cache, project ref, branches)
.supabase/

# Sentry CLI / build plugin
.sentryclirc
.env.sentry-build-plugin

# typescript
*.tsbuildinfo
next-env.d.ts

# Test artifacts
/coverage/
/playwright-report/
/test-results/
/.vitest-cache/
/blob-report/
/playwright/.cache/
/.playwright-mcp/

# Lighthouse local runs (artefactos de smoke manual, no van al repo)
/lighthouse-*.json

# Dumps temporales de debug (T-023-FU4)
/.tmp/

# Backups manuales de Storage (T-082) — contienen PII de clientes, NUNCA al repo
/backups/

# Claude Code harness runtime (wake-up schedules, sessions, etc)
/.claude/

# Config local de herramientas (editor de notas Obsidian + tooling de skills) — no van al repo
.obsidian/
.agents/
skills-lock.json
