{
  "name": "consultora-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level=high",
    "test": "vitest run --project unit --project component",
    "test:watch": "vitest --project unit --project component",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:integration": "node scripts/test-integration-local.mjs",
    "test:integration:remote": "vitest run --project integration --no-file-parallelism",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:local": "node scripts/test-e2e-local.mjs",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:all-browsers": "playwright test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:migration:new": "supabase migration new",
    "db:types": "node scripts/gen-types.mjs --linked",
    "dev:recovery-link": "tsx --env-file=.env.local scripts/dev-generate-recovery-link.ts",
    "dev:smoke-rls-helpers": "tsx --env-file=.env.local scripts/dev-smoke-rls-helpers.ts",
    "dev:smoke-auth-hook": "tsx --env-file=.env.local scripts/dev-smoke-auth-hook.ts",
    "dev:smoke-jwt-claim": "tsx --env-file=.env.local scripts/dev-smoke-jwt-claim.ts",
    "dev:measure-srt-tokens": "tsx --env-file=.env.local scripts/dev-measure-srt-tokens.ts",
    "backup:storage": "tsx --env-file=.env.local scripts/backup-storage.ts",
    "backup:db": "tsx --env-file=.env.local scripts/backup-db.ts",
    "verify:dr-config": "vitest run --project unit src/tests/unit/dr-config-coverage.test.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.55.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "puppeteer-core": "^23.11.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "server-only": "^0.0.1",
    "supabase": "^2.103.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "typescript-eslint": "^8.60.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  }
}
