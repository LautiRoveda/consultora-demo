current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
  echo "❌ Push directo a $current_branch bloqueado por convención auto-impuesta."
  echo ""
  echo "Branch protection server-side está diferida (ver ADR-0004 y"
  echo "docs/technical/05-branch-protection.md). Mientras tanto, este hook"
  echo "actúa como gate local."
  echo ""
  echo "Flow correcto:"
  echo "  git checkout -b feature/T-XXX-descripcion"
  echo "  git push -u origin feature/T-XXX-descripcion"
  echo "  gh pr create --title \"T-XXX · ...\" --fill"
  echo "  # Esperar CI verde sobre el PR"
  echo "  gh pr merge --squash --delete-branch"
  echo ""
  echo "Bypass de emergencia (hot-fix justificado):"
  echo "  git push --no-verify"
  echo "  # Documentar el bypass en el commit msg con prefijo hotfix: o fix!:"
  echo ""
  exit 1
fi

pnpm typecheck
